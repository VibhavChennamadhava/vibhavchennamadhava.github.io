---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Button from '../components/Button.astro';
import { getFeaturedProjects } from '../data/projects';

// Fetch featured projects with GitHub stats at build time
const projects = await getFeaturedProjects(6);

const focusAreas = [
  {
    title: 'Enterprise Networking',
    icon: 'network',
    points: ['CCNA routing/switching', 'VLANs, STP, EtherChannel, OSPF', 'ACLs, NAT, DHCP, troubleshooting'],
  },
  {
    title: 'Security Operations',
    icon: 'shield-alert',
    points: ['Microsoft Sentinel + Wazuh labs', 'Incident triage and evidence notes', 'Vulnerability management workflows'],
  },
  {
    title: 'Cloud & IAM Security',
    icon: 'cloud-cog',
    points: ['Azure/AWS security fundamentals', 'Identity reviews and access hardening', 'Zero Trust and least privilege'],
  },
  {
    title: 'DevSecOps Automation',
    icon: 'workflow',
    points: ['GitHub Actions and Jenkins', 'Terraform/IaC and Linux automation', 'Monitoring, logging, and release hygiene'],
  },
];

const certifications = [
  { name: 'Cisco Certified Network Associate (CCNA)', meta: 'Certified • Enterprise networking, routing/switching, IP services, security fundamentals, and automation' },
  { name: 'CompTIA Security+ (SY0-701)', meta: 'Issued Jul 15, 2025 • Expires Jul 15, 2028' },
  { name: 'ISC2 Certified in Cybersecurity (CC)', meta: 'Issued Nov 13, 2025' },
  { name: 'Google (Coursera) – Foundations of Cybersecurity', meta: 'Completed Mar 1, 2024' },
];

const skillGroups = [
  {
    label: 'Network Infrastructure',
    items: [
      'CCNA-aligned routing, switching, VLAN segmentation, STP, EtherChannel, OSPF, NAT, DHCP, and ACLs.',
      'Packet Tracer lab design with verification steps, troubleshooting notes, and network diagrams.',
      'Security-minded infrastructure documentation for handoff and operations.',
    ],
  },
  {
    label: 'Security Operations & Detection',
    items: [
      'Microsoft Sentinel and Wazuh workflows for alert triage, evidence validation, and escalation notes.',
      'Vulnerability scanning, remediation tracking, and defensive reporting.',
      'MITRE-informed investigation habits from HTB/TryHackMe practice.',
    ],
  },
  {
    label: 'Cloud, IAM & Hardening',
    items: [
      'Cloud security fundamentals across Azure/AWS, access reviews, and least-privilege baselines.',
      'Linux administration, SSH hardening, logging, and configuration management.',
      'Email and DNS security controls including TLS and SPF/DKIM/DMARC.',
    ],
  },
  {
    label: 'DevSecOps & Automation',
    items: [
      'Jenkins, GitHub Actions, and GitLab CI for build/test/deploy pipelines.',
      'Terraform + CloudFormation fundamentals for repeatable infrastructure builds.',
      'Docker/Kubernetes basics with monitoring via Prometheus, Grafana, ELK, and Splunk.',
    ],
  },
];

const ctfProfiles = [
  {
    name: 'Hack The Box',
    href: 'https://app.hackthebox.com/users/1841858',
    badge: 'https://www.hackthebox.com/badge/image/1841858',
  },
  {
    name: 'TryHackMe',
    href: 'https://tryhackme.com/p/vibhav.chennamadhava',
    badge: 'https://tryhackme-badges.s3.amazonaws.com/vibhav.chennamadhava.png?update=1',
  },
];


const timeline = [
  {
    year: '2022–2023',
    title: 'DevOps / Security Support Engineer (Accenture)',
    description: 'Supported enterprise CI/CD and operations while assisting incident investigation, vulnerability remediation tracking, IAM access support, and automation-driven reporting.',
  },
  {
    year: '2024–2025',
    title: 'MS in Cybersecurity (University of North Texas)',
    description: 'Completed SOC-style labs, vulnerability assessment labs with Nmap/Nessus/ZAP, log analysis, network security coursework, and security documentation/writeups.',
  },
  {
    year: '2025–Present',
    title: 'CCNA-Certified Security & Infrastructure Labs',
    description: 'Built CCNA enterprise campus, Microsoft Sentinel, Wazuh, SMTP security, and HTB labs to connect network fundamentals with detection and defensive operations.',
  },
];
---

<BaseLayout title="Sri Vibhav Raju Chennamadhava | DevSecOps • DevOps • Cybersecurity" description="Portfolio for Sri Vibhav Raju Chennamadhava: CCNA-certified cybersecurity, secure network infrastructure, SOC labs, cloud/IAM security, and DevSecOps automation.">
  <Header currentPage="home" />

  <main>
    <Hero />

    <!-- Featured Projects -->
    <section id="projects" class="section bg-bg-primary">
      <div class="container">
        <div class="text-center mb-16">
          <p class="text-xs font-semibold text-accent-coral uppercase tracking-widest mb-2">Featured</p>
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Projects & Labs
          </h2>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Network infrastructure and cybersecurity labs prioritized around CCNA enterprise design, SOC detection, endpoint telemetry, email security, and practical reporting.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {projects.map((project, index) => (
            <div data-animate="fade-up" data-delay={index * 100}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>

        <div class="text-center" data-animate="fade-up" data-delay="600">
          <Button href="/projects" variant="secondary">
            View all projects
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </Button>
        </div>
      </div>
    </section>

    <!-- Skills & Certifications -->
    <section class="section bg-bg-primary">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-6" data-animate="fade-up">
              Core Skills for Security & Infrastructure
            </h2>
            <div class="space-y-5">
              {skillGroups.map((g, idx) => (
                <div class="bg-bg-card border border-border-default rounded-2xl p-6" data-animate="fade-up" data-delay={idx * 90}>
                  <div class="text-sm font-semibold text-text-primary mb-3">{g.label}</div>
                  <ul class="list-disc list-inside space-y-2 text-sm text-text-secondary">
                    {g.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-6" data-animate="fade-up">
              Certifications
            </h2>
            <div class="space-y-4">
              {certifications.map((c, idx) => (
                <div class="bg-bg-card border border-border-default rounded-2xl p-6" data-animate="fade-up" data-delay={idx * 100}>
                  <div class="text-text-primary font-semibold">{c.name}</div>
                  <div class="text-text-muted text-sm mt-1">{c.meta}</div>
                </div>
              ))}
            </div>

            <div class="mt-6" data-animate="fade-up" data-delay="400">
              <Button href="/resume.pdf" variant="secondary" external>
                <i data-lucide="file-text" class="w-5 h-5"></i>
                Download current resume
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Journey -->
    <section class="section bg-bg-secondary">
      <div class="container">
        <h2 class="text-4xl md:text-5xl font-bold text-text-primary text-center mb-12" data-animate="fade-up">
          My Journey
        </h2>

        <div class="max-w-3xl mx-auto">
          <div class="relative">
            <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-border-default md:-translate-x-1/2"></div>

            {timeline.map((item, index) => (
              <div
                class={`relative flex items-start gap-6 mb-8 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}
                data-animate="fade-up"
                data-delay={index * 100}
              >
                <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-accent-coral rounded-full md:-translate-x-1/2 mt-2"></div>

                <div class={`ml-12 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
                  <span class="text-accent-coral font-bold">{item.year}</span>
                  <h3 class="text-xl font-semibold text-text-primary mt-1">{item.title}</h3>
                  <p class="text-text-secondary mt-2">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Focus Areas -->
    <section class="section bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            What I Work On
          </h2>
          <p class="text-lg text-text-secondary" data-animate="fade-up" data-delay="100">
            CCNA-certified network infrastructure, SOC detection, cloud/IAM hardening, and DevSecOps automation.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {focusAreas.map((area, index) => (
            <div
              class="bg-bg-card border border-border-default rounded-2xl p-6 hover:border-border-accent transition-all duration-300"
              data-animate="fade-up"
              data-delay={index * 100}
            >
              <div class="w-12 h-12 rounded-xl bg-bg-hover flex items-center justify-center mb-4">
                <i data-lucide={area.icon} class="w-6 h-6 text-accent-teal"></i>
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-3">{area.title}</h3>
              <ul class="space-y-2 text-sm text-text-secondary">
                {area.points.map((p) => (
                  <li class="flex items-start gap-2">
                    <span class="text-accent-coral mt-0.5">•</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTF Profiles -->
    <section class="section bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            CTF Profiles
          </h2>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Hands-on offensive practice used to strengthen defensive reporting, root-cause analysis, and mitigation recommendations.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          {ctfProfiles.map((p, idx) => (
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-bg-card border border-border-default rounded-2xl p-6 hover:border-border-accent transition-all duration-300"
              data-animate="fade-up"
              data-delay={idx * 100}
            >
              <div class="flex items-center justify-between gap-4 mb-4">
                <div class="text-lg font-semibold text-text-primary">{p.name}</div>
                <div class="text-text-muted text-sm flex items-center gap-2">
                  <span>Open profile</span>
                  <i data-lucide="arrow-up-right" class="w-4 h-4"></i>
                </div>
              </div>

              <img
                src={p.badge}
                alt={`${p.name} badge`}
                loading="lazy"
                class="w-full max-w-[420px] mx-auto rounded-xl border border-border-default bg-bg-hover"
              />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section bg-bg-primary">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center" data-animate="fade-up">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
            Let’s secure reliable infrastructure
          </h2>
          <p class="text-lg text-text-secondary mb-8">
            Open to SOC Analyst, Security Engineer, Network Security, Cloud Security, and DevSecOps roles.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <Button href="/contact" variant="primary">
              Contact
              <i data-lucide="send" class="w-4 h-4"></i>
            </Button>
            <Button href="https://www.linkedin.com/in/vibhav-chennamadhava-61184b190" variant="secondary" external>
              <i data-lucide="linkedin" class="w-5 h-5"></i>
              LinkedIn
            </Button>
            <Button href="https://github.com/VibhavChennamadhava" variant="secondary" external>
              <i data-lucide="github" class="w-5 h-5"></i>
              GitHub
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate sections on scroll
  document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
    const delay = parseInt(el.getAttribute('data-delay') || '0') / 1000;

    gsap.from(el, {
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.6,
      delay,
      ease: 'power2.out',
    });
  });
</script>
